{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "observedAt": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "gameVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "locale": {
      "type": "string",
      "enum": [
        "ko",
        "en"
      ]
    },
    "region": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "source": {
      "type": "string",
      "enum": [
        "xchg_search"
      ]
    },
    "item": {
      "type": "object",
      "properties": {
        "configBaseId": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      },
      "required": [
        "configBaseId"
      ],
      "additionalProperties": false
    },
    "price": {
      "type": "object",
      "properties": {
        "currency": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "unitPrices": {
          "minItems": 1,
          "maxItems": 1000,
          "type": "array",
          "items": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "ref": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "currency",
        "unitPrices",
        "ref"
      ],
      "additionalProperties": false
    },
    "client": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12})$"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[0-9A-Za-z][0-9A-Za-z.+-]*$"
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "observedAt",
    "gameVersion",
    "locale",
    "region",
    "source",
    "item",
    "price",
    "client"
  ],
  "additionalProperties": false,
  "$id": "urn:smng-ti-schema:v1:price-observation",
  "title": "price-observation",
  "description": "smng-ti-overlay에서 smng-ti-pricer로 보내는 익명 거래소 가격 관측치"
}
